# Database
MEDUSA_DB_PASSWORD=changeme

# Medusa secrets — generate with: openssl rand -hex 32
MEDUSA_JWT_SECRET=replace_with_long_random_string
MEDUSA_COOKIE_SECRET=replace_with_long_random_string

# Domains (Traefik routing)
DOMAIN_NAME=example.com
SUBDOMAIN=app
MEDUSA_DOMAIN=example.com
MEDUSA_SUBDOMAIN=shop

# Cloudflare R2 (object storage)
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret

# Payments
STRIPE_API_KEY=sk_test_xxxxxxxx
PAYPAL_CLIENT_SECRET=your_paypal_secret

# Email
RESEND_API_KEY=re_xxxxxxxx

# CORS — comma-separated list of allowed frontend origins
STORE_CORS=https://example.com,https://beta.example.com
ADMIN_CORS=https://example.com,https://beta.example.com
AUTH_CORS=https://example.com,https://beta.example.com
